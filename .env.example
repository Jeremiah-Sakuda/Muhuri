# Backend selector: "memory" (default, zero cloud deps) or "dynamo" (real AWS).
MUHURI_BACKEND=memory

# ---- required when MUHURI_BACKEND=dynamo ----
AWS_REGION=us-east-1
MUHURI_TABLE=Muhuri
MUHURI_WITNESS_BUCKET=your-object-lock-bucket

# Stable Ed25519 PEM for the timestamp authority (printed by `npm run setup:dynamo`).
# Publish the corresponding public key. If unset, an ephemeral key is generated
# per cold start — still self-verifying per proof, since each proof carries its
# own public key, but not stable across deploys.
MUHURI_TSA_PRIVATE_KEY=

# AWS credentials — or use an IAM role / the Vercel AWS integration instead.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
